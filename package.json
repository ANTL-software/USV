{
  "name": "antl-usv",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "npm run test:unit && npm run test:e2e && npm run test:browser",
    "test:unit": "node --test --experimental-strip-types --experimental-test-module-mocks tests/unit/*.test.ts",
    "test:e2e": "node --test --experimental-strip-types --experimental-test-module-mocks tests/e2e/*.test.ts",
    "test:browser": "playwright test",
    "test:browser:headed": "playwright test --headed",
    "preview": "vite preview"
  },
  "dependencies": {
    "@react-pdf-viewer/core": "^3.12.0",
    "@react-pdf-viewer/default-layout": "^3.12.0",
