    "@types/react-color": "^3.0.13",
    "aos": "^2.3.4",
    "axios": "^1.18.1",
    "date-fns": "^4.1.0",
    "react": "^19.2.4",
    "react-big-calendar": "^1.19.4",
    "react-color": "^2.19.3",
    "react-dom": "^19.2.4",
    "react-icons": "^5.4.0",
    "react-image-crop": "^11.0.10",
    "react-pdf": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "react-select": "^5.10.2",
    "recharts": "^3.8.1",
    "sass": "^1.82.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "1.58.2",
